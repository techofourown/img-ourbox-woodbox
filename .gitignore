# build outputs
/deploy/
/deploy-from-registry/

# downloaded artifacts
/artifacts/

# temp work dirs
/tmp/

# sentinel written by prepare-installer-media.sh after work begins;
# presence means this tree has been used — run: git clean -fdx
/.used

# OS cruft
.DS_Store


# installer-side artifact pull cache (populated at install time in live env)
/installer/ourbox/rootfs/opt/ourbox/airgap/platform/manifests/*.yaml
/installer/ourbox/rootfs/opt/ourbox/airgap/platform/landing/*.html
/installer/ourbox/rootfs/opt/ourbox/airgap/platform/landing/*.js
/installer/ourbox/rootfs/opt/ourbox/airgap/platform/landing/*.css
/installer/ourbox/rootfs/opt/ourbox/airgap/platform/todo-bloom/*.html
/installer/ourbox/rootfs/opt/ourbox/airgap/platform/todo-bloom/*.js
/installer/ourbox/rootfs/opt/ourbox/airgap/platform/todo-bloom/*.css
/installer/ourbox/rootfs/opt/ourbox/airgap/platform/contract.env
/installer/ourbox/rootfs/opt/ourbox/airgap/platform/contract.digest

# installer artifact pull cache
/deploy-installer-from-registry/

# local registry overrides (never commit)
/tools/local/
