#!/usr/bin/env bash
# OurBox Woodbox — pre-installer
# Runs on TTY1 before Subiquity. Collects disk + identity from the operator,
# writes /autoinstall.yaml, then exits so Subiquity can run fully automated.
set -euo pipefail

# Tee all output to the installer log so the network monitor can broadcast it.
# The monitor (ourbox-installer-monitor.py) tails this file and rebroadcasts
# each line via UDP and an HTTP viewer on port 8888.
INSTALLER_LOG="/run/ourbox-installer.log"
exec > >(tee -a "${INSTALLER_LOG}") 2>&1

# shellcheck disable=SC1091
source /cdrom/ourbox/tools/lib.sh

need_cmd lsblk
need_cmd readlink
need_cmd findmnt
need_cmd udevadm
need_cmd openssl
need_cmd envsubst
need_cmd awk
need_cmd sed

AUTOINSTALL_TPL="/cdrom/ourbox/autoinstall.tpl"
AUTOINSTALL_OUT="/autoinstall.yaml"
DEFAULTS_ENV="/cdrom/ourbox/installer/defaults.env"
PAYLOAD_CACHE_DIR="/opt/ourbox/installer/cache/payload"

# ---------------------------------------------------------------------------
# helpers
# ---------------------------------------------------------------------------

banner() {
  local ip
  ip="$(ip route get 10.255.255.255 2>/dev/null | awk '/src/ {print $7; exit}' || true)"
  clear
  echo
  echo "  =================================================================="
  echo "  OurBox Woodbox — Installer"
  echo "  =================================================================="
  if [[ -n "${ip}" ]]; then
    echo "  Network monitoring:"
    echo "    SSH     : ssh ubuntu@${ip}   (password: ourbox-install)"
    echo "    Browser : http://${ip}:8888/"
    echo "    UDP     : socat UDP-RECV:9999,reuseaddr -"
  fi
  echo "  =================================================================="
  echo
}

prompt_confirm_exact() {
  local expected="$1" prompt="$2" ans=""
  read -r -p "${prompt} " ans
  [[ "${ans}" == "${expected}" ]] || die "confirmation did not match (expected: ${expected})"
}

# ---------------------------------------------------------------------------
# disk detection
# ---------------------------------------------------------------------------

installer_disk() {
  # The disk backing the live USB (the one / is on)
  local src real parent
  src="$(findmnt -nr -o SOURCE / 2>/dev/null || true)"
  real="$(readlink -f "${src}" 2>/dev/null || echo "${src}")"
  parent="$(lsblk -no PKNAME "${real}" 2>/dev/null || true)"
  if [[ -n "${parent}" ]]; then
    echo "/dev/${parent}"
  else
    echo "${real}"
  fi
}

# OS disk candidates: any non-removable disk except the installer USB.
candidate_disks() {
  local installer
  installer="$(installer_disk)"
  lsblk -dn -o NAME,TYPE | awk '$2=="disk" {print "/dev/"$1}' | while read -r disk; do
    [[ "${disk}" != "${installer}" ]] || continue
    local rm
    rm="$(lsblk -dn -o RM "${disk}" 2>/dev/null | tr -d '[:space:]')"
    [[ "${rm}" != "1" ]] || continue
    echo "${disk}"
  done
}

# DATA disk candidates: non-removable, not the installer USB, not the OS disk.
# Any transport type (SATA, SAS, NVMe, etc.) — identified by exclusion, not size.
candidate_data_disks() {
  local installer os_disk
  installer="$(installer_disk)"
  os_disk="${TARGET_DISK}"
  lsblk -dn -o NAME,TYPE | awk '$2=="disk" {print "/dev/"$1}' | while read -r disk; do
    [[ "${disk}" != "${installer}" ]] || continue
    [[ "${disk}" != "${os_disk}" ]]  || continue
    local rm
    rm="$(lsblk -dn -o RM "${disk}" 2>/dev/null | tr -d '[:space:]')"
    [[ "${rm}" != "1" ]] || continue
    echo "${disk}"
  done
}

_disk_table_row() {
  local disk="$1" idx="$2"
  local size tran model serial
  size="$(lsblk -dn -o SIZE "${disk}" 2>/dev/null | tr -d '[:space:]')"
  tran="$(lsblk -dn -o TRAN "${disk}" 2>/dev/null | tr -d '[:space:]' | tr '[:upper:]' '[:lower:]')"
  model="$(lsblk -dn -o MODEL "${disk}" 2>/dev/null | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
  serial="$(lsblk -dn -o SERIAL "${disk}" 2>/dev/null | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
  [[ -n "${tran}" ]]   || tran="-"
  [[ -n "${model}" ]]  || model="-"
  [[ -n "${serial}" ]] || serial="-"
  printf '  %-3s %-14s %-8s %-6s %-22.22s %-16.16s\n' \
    "${idx}" "${disk}" "${size}" "${tran}" "${model}" "${serial}"
}

_disk_table_header() {
  printf '\n  %-3s %-14s %-8s %-6s %-22s %-16s\n' \
    "#" "Device" "Size" "Tran" "Model" "Serial"
  echo "  -----------------------------------------------------------------------"
}

print_disk_table() {
  local idx=0
  _disk_table_header
  while read -r disk; do
    idx=$((idx + 1))
    _disk_table_row "${disk}" "${idx}"
  done < <(candidate_disks)
  echo
}

print_data_disk_table() {
  local idx=0
  _disk_table_header
  while read -r disk; do
    idx=$((idx + 1))
    _disk_table_row "${disk}" "${idx}"
  done < <(candidate_data_disks)
  echo
}

select_disk() {
  local disks=() idx selected serial

  while true; do
    mapfile -t disks < <(candidate_disks)

    if (( ${#disks[@]} == 0 )); then
      echo
      echo "  No OS disk candidates found (non-removable, non-USB)."
      echo "  Make sure a target disk is connected, then rescan."
      read -r -p "  Press ENTER to rescan, or q to quit: " _ans
      [[ "${_ans}" == "q" || "${_ans}" == "Q" ]] && die "operator quit"
      continue
    fi

    print_disk_table
    read -r -p "  Select OS disk number (r=rescan, q=quit): " _ans
    case "${_ans}" in
      r|R) continue ;;
      q|Q) die "operator quit" ;;
    esac

    [[ "${_ans}" =~ ^[0-9]+$ ]] || { log "invalid selection"; continue; }
    idx=$(( _ans - 1 ))
    (( idx >= 0 && idx < ${#disks[@]} )) || { log "selection out of range"; continue; }

    selected="${disks[${idx}]}"
    echo
    lsblk -o NAME,SIZE,MODEL,SERIAL,TYPE,FSTYPE,LABEL,MOUNTPOINTS "${selected}" || true
    echo
    prompt_confirm_exact "INSTALL-TO-THIS-DISK" \
      "  Type INSTALL-TO-THIS-DISK to confirm this is the OS disk:"

    serial="$(lsblk -dn -o SERIAL "${selected}" 2>/dev/null | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    TARGET_DISK="${selected}"
    TARGET_DISK_SERIAL="${serial}"
    return 0
  done
}

select_data_disk() {
  local disks=() idx selected

  while true; do
    mapfile -t disks < <(candidate_data_disks)

    if (( ${#disks[@]} == 0 )); then
      echo
      echo "  No DATA disk candidates found (non-removable, non-OS, non-USB)."
      echo "  Make sure the data drive is connected, then rescan."
      read -r -p "  Press ENTER to rescan, or q to quit: " _ans
      [[ "${_ans}" == "q" || "${_ans}" == "Q" ]] && die "operator quit"
      continue
    fi

    print_data_disk_table
    read -r -p "  Select DATA disk number (r=rescan, q=quit): " _ans
    case "${_ans}" in
      r|R) continue ;;
      q|Q) die "operator quit" ;;
    esac

    [[ "${_ans}" =~ ^[0-9]+$ ]] || { log "invalid selection"; continue; }
    idx=$(( _ans - 1 ))
    (( idx >= 0 && idx < ${#disks[@]} )) || { log "selection out of range"; continue; }

    selected="${disks[${idx}]}"
    echo
    lsblk -o NAME,SIZE,MODEL,SERIAL,TYPE,FSTYPE,LABEL,MOUNTPOINTS "${selected}" || true
    echo
    echo "  WARNING: ALL DATA ON ${selected} WILL BE PERMANENTLY ERASED"
    echo "  and formatted as the OurBox data volume (LABEL=OURBOX_DATA)."
    echo
    prompt_confirm_exact "FORMAT-AS-DATA" \
      "  Type FORMAT-AS-DATA to confirm this is the data disk:"

    DATA_DISK="${selected}"
    return 0
  done
}

# ---------------------------------------------------------------------------
# OS artifact resolution — Matchbox-style install defaults / catalog lane
# ---------------------------------------------------------------------------

# Globals set by resolve_and_stage_os_artifact:
OS_ARTIFACT_SOURCE=""
OS_ARTIFACT_REF=""
OS_ARTIFACT_DIGEST=""
OS_IMAGE_SHA256=""
INSTALLER_ID="woodbox"
OS_CHANNEL="stable"
INSTALL_DEFAULTS_SOURCE="baked"
INSTALL_DEFAULTS_REF=""

# Any helper used inside command substitution must keep stdout machine-readable.
# Human-readable logs belong on stderr, or captured values can be contaminated.
_is_clean_single_line_ref() {
  local ref="$1"
  [[ -n "${ref}" ]] || return 1
  [[ "${ref}" != *$'\n'* && "${ref}" != *$'\r'* ]] || return 1
  [[ ! "${ref}" =~ [[:space:]] ]] || return 1
  return 0
}

_is_digest_pinned_ref() {
  local ref="$1"
  _is_clean_single_line_ref "${ref}" || return 1
  [[ "${ref}" =~ ^[^[:space:]]+@sha256:[0-9a-f]{64}$ ]] || return 1
  return 0
}

# _try_catalog_resolve REPO CATALOG_TAG CHANNEL
# If the catalog TSV is available and has a digest-pinned entry for CHANNEL,
# print the pinned_ref (last column) for the most-recent matching row and
# return 0. If the catalog is unavailable or has no valid entry, print nothing
# and return 1. The caller handles the fallback and tracks the source.
_try_catalog_resolve() {
  local repo="$1" catalog_tag="$2" channel="$3"
  local catalog_dir
  catalog_dir="$(mktemp -d)"
  # shellcheck disable=SC2064
  trap "rm -rf '${catalog_dir}'" RETURN

  set +e
  oras pull "${repo}:${catalog_tag}" -o "${catalog_dir}" >/dev/null 2>&1
  local pull_status=$?
  set -e

  if [[ "${pull_status}" -ne 0 || ! -f "${catalog_dir}/catalog.tsv" ]]; then
    log "  Catalog not available" >&2
    return 1
  fi

  # Catalog columns: channel created version variant target sku git_sha
  #   platform_contract_digest k3s_version payload_sha256 artifact_digest pinned_ref
  # Channel column uses short names (stable, nightly). pinned_ref is last column.
  local pinned_ref
  pinned_ref="$(awk -F'\t' -v ch="${channel}" \
    'NR>1 && $1==ch {last=$(NF)} END{if(last!="")print last}' \
    "${catalog_dir}/catalog.tsv" 2>/dev/null || true)"

  if _is_digest_pinned_ref "${pinned_ref}"; then
    log "  Catalog resolved '${channel}' → ${pinned_ref}" >&2
    echo "${pinned_ref}"
    return 0
  else
    log "  Catalog has no valid digest-pinned entry for channel '${channel}'" >&2
    return 1
  fi
}

# _stage_embedded_payload — copy embedded payload from fat ISO into cache dir
_stage_embedded_payload() {
  local embedded="/cdrom/ourbox/payload/os-payload.tar.gz"
  mkdir -p "${PAYLOAD_CACHE_DIR}"
  cp "${embedded}" "${PAYLOAD_CACHE_DIR}/os-payload.tar.gz"
  [[ -f "${embedded}.sha256" ]] && \
    cp "${embedded}.sha256" "${PAYLOAD_CACHE_DIR}/os-payload.tar.gz.sha256"
  [[ -f "/cdrom/ourbox/payload/payload.meta.env" ]] && \
    cp "/cdrom/ourbox/payload/payload.meta.env" "${PAYLOAD_CACHE_DIR}/payload.meta.env"
}

# _verify_staged_payload — verify SHA256 and set OS_IMAGE_SHA256
_verify_staged_payload() {
  [[ -f "${PAYLOAD_CACHE_DIR}/os-payload.tar.gz" ]] || \
    die "OS payload not staged: ${PAYLOAD_CACHE_DIR}/os-payload.tar.gz"

  local sha256_file="${PAYLOAD_CACHE_DIR}/os-payload.tar.gz.sha256"
  if [[ -f "${sha256_file}" ]]; then
    local expected actual
    expected="$(awk 'NF>=1 {print $1; exit}' "${sha256_file}")"
    expected="${expected,,}"
    [[ "${expected}" =~ ^[0-9a-f]{64}$ ]] || die "invalid sha256 in os-payload.tar.gz.sha256"
    actual="$(sha256sum "${PAYLOAD_CACHE_DIR}/os-payload.tar.gz" | awk '{print $1}')"
    [[ "${expected}" == "${actual}" ]] || \
      die "OS payload SHA256 mismatch
  expected: ${expected}
  actual:   ${actual}"
    OS_IMAGE_SHA256="${actual}"
    log "  SHA256 verified: ${actual}"
  else
    OS_IMAGE_SHA256="$(sha256sum "${PAYLOAD_CACHE_DIR}/os-payload.tar.gz" | awk '{print $1}')"
    log "  SHA256: ${OS_IMAGE_SHA256} (no checksum file; not verified against expected)"
  fi
}

# _show_artifact_panel — display the resolved artifact info before final confirmation
_show_artifact_panel() {
  local meta_env="${PAYLOAD_CACHE_DIR}/payload.meta.env"
  local payload_version="unknown" payload_variant="unknown" payload_contract_digest="unknown"
  if [[ -f "${meta_env}" ]]; then
    # shellcheck disable=SC1090
    source "${meta_env}"
    payload_version="${OURBOX_VERSION:-unknown}"
    payload_variant="${OURBOX_VARIANT:-unknown}"
    payload_contract_digest="${OURBOX_PLATFORM_CONTRACT_DIGEST:-unknown}"
  fi

  echo
  echo "  =================================================================="
  echo "  OS Artifact"
  echo "  =================================================================="
  echo "  Source   : ${OS_ARTIFACT_SOURCE}"
  echo "  Ref      : ${OS_ARTIFACT_REF}"
  if [[ -n "${OS_ARTIFACT_DIGEST}" && "${OS_ARTIFACT_DIGEST}" != "embedded" ]]; then
    echo "  Digest   : ${OS_ARTIFACT_DIGEST}"
  fi
  echo "  SHA256   : ${OS_IMAGE_SHA256}"
  echo "  Version  : ${payload_version}"
  echo "  Variant  : ${payload_variant}"
  echo "  Contract : ${payload_contract_digest}"
  echo "  Defaults : ${INSTALL_DEFAULTS_SOURCE}"
  echo "  =================================================================="
  echo
}

resolve_and_stage_os_artifact() {
  banner
  echo "  Resolving OS artifact"
  echo

  [[ -f "${DEFAULTS_ENV}" ]] || die "missing installer defaults: ${DEFAULTS_ENV}"
  # shellcheck disable=SC1090
  source "${DEFAULTS_ENV}"

  INSTALLER_ID="${INSTALLER_ID:-woodbox}"
  OS_CHANNEL="${OS_CHANNEL:-stable}"
  OS_REPO="${OS_REPO:-ghcr.io/techofourown/ourbox-woodbox-os}"
  OS_TARGET="${OS_TARGET:-x86}"
  OS_DEFAULT_REF="${OS_DEFAULT_REF:-}"
  OS_CATALOG_ENABLED="${OS_CATALOG_ENABLED:-1}"
  OS_CATALOG_TAG="${OS_CATALOG_TAG:-x86-catalog}"
  INSTALL_DEFAULTS_SOURCE="baked"
  INSTALL_DEFAULTS_REF="${INSTALL_DEFAULTS_REF:-}"

  mkdir -p "${PAYLOAD_CACHE_DIR}"

  # --- Path A: embedded payload (fat ISO / offline) ---
  # Takes precedence over all registry paths; no network needed.
  local embedded_payload="/cdrom/ourbox/payload/os-payload.tar.gz"
  if [[ -f "${embedded_payload}" ]]; then
    log "  Embedded OS payload detected (fat-ISO / offline mode)"
    _stage_embedded_payload
    OS_ARTIFACT_SOURCE="embedded"
    OS_ARTIFACT_REF="embedded"
    OS_ARTIFACT_DIGEST="embedded"
    _verify_staged_payload
    _show_artifact_panel
    return 0
  fi

  # --- All registry paths require ORAS ---
  need_cmd oras

  # --- Remote install-defaults bundle (optional, overlays baked defaults) ---
  # If INSTALL_DEFAULTS_REF is set in baked defaults, try to pull the remote
  # install-defaults bundle. On success, overlay its values on top of the baked
  # defaults (remote wins). On failure, fall through cleanly to baked values.
  # The bundle is an OCI artifact containing install-defaults.env.
  if [[ -n "${INSTALL_DEFAULTS_REF}" ]]; then
    log "  Fetching remote install-defaults: ${INSTALL_DEFAULTS_REF}"
    local defaults_tmp defaults_pull_ok
    defaults_tmp="$(mktemp -d)"
    set +e
    oras pull "${INSTALL_DEFAULTS_REF}" -o "${defaults_tmp}" >/dev/null 2>&1
    defaults_pull_ok=$?
    set -e
    if [[ "${defaults_pull_ok}" -eq 0 && -f "${defaults_tmp}/install-defaults.env" ]]; then
      log "  Remote install-defaults pulled; overlaying on baked defaults"
      # shellcheck disable=SC1091
      source "${defaults_tmp}/install-defaults.env"
      INSTALL_DEFAULTS_SOURCE="remote"
      # INSTALL_DEFAULTS_REF stays as the OCI ref used
    else
      log "  WARNING: Remote install-defaults pull failed; using baked fallback"
      INSTALL_DEFAULTS_SOURCE="baked"
    fi
    rm -rf "${defaults_tmp}"
  fi

  # Re-apply defaults that may have been updated by remote install-defaults:
  OS_CHANNEL="${OS_CHANNEL:-stable}"
  OS_DEFAULT_REF="${OS_DEFAULT_REF:-}"

  # --- Precedence 1: OS_DEFAULT_REF (baked or remote) ---
  # If a pinned OS artifact ref is already known (from baked or remote defaults),
  # use it directly — skip catalog and channel resolution entirely.
  local explicit_ref=""
  if [[ -n "${OS_DEFAULT_REF}" ]]; then
    explicit_ref="${OS_DEFAULT_REF}"
    log "  OS_DEFAULT_REF set: ${explicit_ref}"
    if [[ "${INSTALL_DEFAULTS_SOURCE}" == "remote" ]]; then
      : # INSTALL_DEFAULTS_SOURCE already correct
    else
      INSTALL_DEFAULTS_SOURCE="baked-pinned"
    fi
  fi

  # --- Precedence 2 / 3: catalog resolution or channel tag fallback ---
  local channel_tag_ref="${OS_REPO}:${OS_TARGET}-${OS_CHANNEL}"
  local selected_ref=""

  if [[ -n "${explicit_ref}" ]]; then
    selected_ref="${explicit_ref}"
  elif [[ "${OS_CATALOG_ENABLED}" == "1" ]]; then
    local catalog_result
    local catalog_result_q=""
    set +e
    catalog_result="$(_try_catalog_resolve \
      "${OS_REPO}" "${OS_CATALOG_TAG}" "${OS_CHANNEL}")"
    local catalog_ok=$?
    set -e
    if [[ "${catalog_ok}" -eq 0 ]] && _is_digest_pinned_ref "${catalog_result}"; then
      selected_ref="${catalog_result}"
      if [[ "${INSTALL_DEFAULTS_SOURCE}" == "baked" ]]; then
        INSTALL_DEFAULTS_SOURCE="catalog"
      fi
    else
      if [[ "${catalog_ok}" -eq 0 ]]; then
        printf -v catalog_result_q '%q' "${catalog_result}"
        log "  WARNING: Catalog output was invalid or contaminated; falling back to channel tag"
        log "  Raw catalog output (shell-escaped): ${catalog_result_q}"
      fi
      selected_ref="${channel_tag_ref}"
      if [[ "${INSTALL_DEFAULTS_SOURCE}" == "baked" ]]; then
        INSTALL_DEFAULTS_SOURCE="tag"
      fi
      log "  Using channel tag fallback: ${channel_tag_ref}"
    fi
  else
    selected_ref="${channel_tag_ref}"
    if [[ "${INSTALL_DEFAULTS_SOURCE}" == "baked" ]]; then
      INSTALL_DEFAULTS_SOURCE="tag"
    fi
  fi

  [[ -n "${selected_ref}" ]] || { selected_ref="${channel_tag_ref}"; INSTALL_DEFAULTS_SOURCE="tag"; }

  # --- Operator interactive override ---
  # Show the resolved ref and offer the operator a chance to substitute an exact
  # ref without requiring ISO remastering. Pressing Enter accepts the resolved ref.
  echo
  echo "  =================================================================="
  echo "  Resolved OS artifact ref:"
  echo "    ${selected_ref}"
  echo "  Source: ${INSTALL_DEFAULTS_SOURCE}"
  echo "  =================================================================="
  echo
  local override_input=""
  read -r -p "  Override ref (press Enter to accept, or type an exact ref/digest): " override_input
  if [[ -n "${override_input}" ]]; then
    log "  Operator supplied override ref: ${override_input}"
    selected_ref="${override_input}"
    INSTALL_DEFAULTS_SOURCE="operator-override"
    INSTALL_DEFAULTS_REF=""
  fi

  local selected_ref_q=""
  if ! _is_clean_single_line_ref "${selected_ref}"; then
    printf -v selected_ref_q '%q' "${selected_ref}"
    die "invalid selected OS artifact ref (must be non-empty, single-line, no whitespace): ${selected_ref_q}"
  fi

  # --- Resolve floating ref to immutable digest ---
  # Always pull by digest so the installed system has an exact artifact identity.
  local pull_ref="${selected_ref}"
  OS_ARTIFACT_DIGEST=""
  if [[ "${selected_ref}" =~ @sha256:[0-9a-f]{64}$ ]]; then
    # Already digest-pinned — extract the digest component.
    OS_ARTIFACT_DIGEST="${selected_ref##*@}"
  else
    log "  Resolving to immutable digest: ${selected_ref}"
    local resolved_digest
    set +e
    resolved_digest="$(oras resolve "${selected_ref}" 2>/dev/null)"
    local resolve_status=$?
    set -e
    if [[ "${resolve_status}" -eq 0 && "${resolved_digest}" =~ ^sha256:[0-9a-f]{64}$ ]]; then
      OS_ARTIFACT_DIGEST="${resolved_digest}"
      # Pull by digest for immutability; keep original ref for provenance display.
      # Strip the tag suffix (last colon onwards) to get the repo+name without tag.
      # Use % (shortest suffix match) not %% (longest) so that refs containing
      # a port (e.g. localhost:5000/repo/image:tag) are handled correctly.
      local repo_base="${selected_ref%:*}"
      pull_ref="${repo_base}@${resolved_digest}"
      log "  Resolved: ${resolved_digest}"
    else
      # oras resolve failed: artifact identity cannot be established before pull.
      # By default this is a hard failure — pulling by a floating tag installs an
      # unverified artifact whose identity cannot be recorded in provenance.
      # Set OURBOX_ALLOW_UNRESOLVED_PULL=1 only for development / testing.
      if [[ "${OURBOX_ALLOW_UNRESOLVED_PULL:-0}" == "1" ]]; then
        log "  WARNING: oras resolve failed; pulling by tag (OURBOX_ALLOW_UNRESOLVED_PULL=1)"
        log "  WARNING: artifact identity will not be captured in provenance"
        pull_ref="${selected_ref}"
      else
        die "Cannot establish artifact identity: oras resolve failed for ${selected_ref}
  The installer requires a digest-pinned artifact ref to ensure provenance.
  Options:
    1. Use a digest-pinned ref (catalog or OS_DEFAULT_REF usually provides this)
    2. Check registry connectivity and retry
    3. Set OURBOX_ALLOW_UNRESOLVED_PULL=1 to skip this check (dev/testing only)"
      fi
    fi
  fi

  OS_ARTIFACT_SOURCE="registry"
  OS_ARTIFACT_REF="${selected_ref}"

  echo "  Pulling OS artifact:"
  echo "    ${pull_ref}"
  echo

  local pull_out pull_status
  set +e
  pull_out="$(oras pull "${pull_ref}" -o "${PAYLOAD_CACHE_DIR}" 2>&1)"
  pull_status=$?
  set -e
  printf '%s\n' "${pull_out}"
  [[ "${pull_status}" -eq 0 ]] || die "oras pull failed for ${pull_ref} (exit ${pull_status})"

  # OS_ARTIFACT_DIGEST is set from oras resolve (or from an @sha256: pinned ref).
  # In OURBOX_ALLOW_UNRESOLVED_PULL=1 mode it is still empty — mark it explicitly
  # so provenance records the ambiguous state rather than silently recording empty.
  if [[ -z "${OS_ARTIFACT_DIGEST}" ]]; then
    OS_ARTIFACT_DIGEST="unresolved"
  fi

  _verify_staged_payload
  _show_artifact_panel
}

write_install_provenance() {
  local cache_dir="/opt/ourbox/installer/cache"
  mkdir -p "${cache_dir}"

  # RELEASE_CHANNEL is only meaningful for moving-channel resolution.
  # For embedded payloads and explicit-ref overrides, record empty string
  # rather than claiming a channel that wasn't actually used for selection.
  local release_channel=""
  if [[ "${INSTALL_DEFAULTS_SOURCE}" == "catalog" || "${INSTALL_DEFAULTS_SOURCE}" == "tag" ]]; then
    release_channel="${OS_CHANNEL:-unknown}"
  fi

  # Write env file consumed by the late-commands append-provenance.sh script.
  # INSTALLER_VERSION and INSTALLER_GIT_HASH come from defaults.env (baked at
  # ISO build time); they uniquely identify the installer artifact that ran.
  cat > "${cache_dir}/install-provenance.env" <<EOF
INSTALLER_ID=${INSTALLER_ID:-woodbox}
INSTALLER_VERSION=${INSTALLER_VERSION:-unknown}
INSTALLER_GIT_HASH=${INSTALLER_GIT_HASH:-unknown}
OS_ARTIFACT_SOURCE=${OS_ARTIFACT_SOURCE:-unknown}
OS_ARTIFACT_REF=${OS_ARTIFACT_REF:-unknown}
OS_ARTIFACT_DIGEST=${OS_ARTIFACT_DIGEST:-unknown}
OS_IMAGE_SHA256=${OS_IMAGE_SHA256:-unknown}
RELEASE_CHANNEL=${release_channel}
INSTALL_DEFAULTS_SOURCE=${INSTALL_DEFAULTS_SOURCE:-baked}
INSTALL_DEFAULTS_REF=${INSTALL_DEFAULTS_REF:-}
EOF

  # Write the provenance-append script called by autoinstall.tpl late-commands.
  # Single-quoted heredoc: variable references are literal in the script body
  # and expand at runtime (after sourcing install-provenance.env).
  cat > "${cache_dir}/append-provenance.sh" <<'SCRIPT'
#!/bin/sh
set -e
PROV="/opt/ourbox/installer/cache/install-provenance.env"
TARGET="${1:-/target}"
if [ ! -f "${PROV}" ]; then
  echo "append-provenance.sh: ${PROV} not found, skipping" >&2
  exit 0
fi
# shellcheck disable=SC1090
. "${PROV}"
cat >> "${TARGET}/etc/ourbox/release" <<EOT
OURBOX_INSTALLER_ID=${INSTALLER_ID:-woodbox}
OURBOX_INSTALLER_VERSION=${INSTALLER_VERSION:-unknown}
OURBOX_INSTALLER_GIT_HASH=${INSTALLER_GIT_HASH:-unknown}
OURBOX_OS_ARTIFACT_SOURCE=${OS_ARTIFACT_SOURCE:-unknown}
OURBOX_OS_ARTIFACT_REF=${OS_ARTIFACT_REF:-unknown}
OURBOX_OS_ARTIFACT_DIGEST=${OS_ARTIFACT_DIGEST:-unknown}
OURBOX_OS_IMAGE_SHA256=${OS_IMAGE_SHA256:-unknown}
OURBOX_RELEASE_CHANNEL=${RELEASE_CHANNEL:-unknown}
OURBOX_INSTALL_DEFAULTS_SOURCE=${INSTALL_DEFAULTS_SOURCE:-baked}
OURBOX_INSTALL_DEFAULTS_REF=${INSTALL_DEFAULTS_REF:-}
EOT
SCRIPT
  chmod +x "${cache_dir}/append-provenance.sh"
}

# ---------------------------------------------------------------------------
# identity
# ---------------------------------------------------------------------------

prompt_nonempty() {
  local prompt="$1" default="${2:-}" ans=""
  if [[ -n "${default}" ]]; then
    read -r -p "  ${prompt} [${default}]: " ans
    ans="${ans:-${default}}"
  else
    read -r -p "  ${prompt}: " ans
  fi
  [[ -n "${ans}" ]] || die "value required"
  echo "${ans}"
}

prompt_password_hash() {
  local pw1="" pw2=""
  while true; do
    # echo after read -s moves the cursor to a new line; must go to stderr
    # so that only the hash is captured by $(...) on stdout.
    read -r -s -p "  Password: " pw1; echo >&2
    read -r -s -p "  Confirm:  " pw2; echo >&2
    [[ -n "${pw1}" ]] || { echo "  Password cannot be empty." >&2; continue; }
    [[ "${pw1}" == "${pw2}" ]] || { echo "  Passwords did not match. Try again." >&2; continue; }
    echo "${pw1}" | openssl passwd -6 -stdin
    return 0
  done
}

# ---------------------------------------------------------------------------
# main
# ---------------------------------------------------------------------------

main() {
  banner

  udevadm settle --timeout=10 || true

  # --- Step 1: OS disk ---
  echo "  Step 1 of 5: Select the OS disk"
  echo "  This disk will be ERASED and OurBox Woodbox OS installed on it."
  echo "  Showing all non-removable, non-USB disks."
  echo "  Recommendation: use a faster SSD/NVMe drive for best performance."

  TARGET_DISK=""
  TARGET_DISK_SERIAL=""
  select_disk

  echo
  echo "  OS disk     : ${TARGET_DISK}"
  echo "  Disk serial : ${TARGET_DISK_SERIAL:-unknown}"
  echo

  # --- Step 2: DATA disk ---
  banner
  echo "  Step 2 of 5: Select the DATA disk"
  echo "  This disk will be formatted as the OurBox data volume."
  echo "  Showing all non-OS, non-removable disks."

  DATA_DISK=""
  select_data_disk

  echo
  echo "  DATA disk   : ${DATA_DISK}"
  echo

  # --- Step 3: OS artifact ---
  banner
  echo "  Step 3 of 5: Resolve OS artifact"
  echo "  Checking for embedded payload or pulling from registry..."
  echo
  resolve_and_stage_os_artifact
  write_install_provenance

  # --- Step 4: Identity ---
  banner
  echo "  Step 4 of 5: Set identity for the installed system"
  echo "  (You can change hostname and password later.)"
  echo

  OURBOX_HOSTNAME="$(prompt_nonempty "Hostname" "ourbox-woodbox")"
  OURBOX_USERNAME="$(prompt_nonempty "Username" "ourbox")"

  echo
  echo "  Set the login password for ${OURBOX_USERNAME}:"
  OURBOX_PASSWORD_HASH="$(prompt_password_hash)"

  # --- Step 5: Summary + final confirmation ---
  banner
  echo "  Step 5 of 5: Confirm and install"
  echo
  echo "  OS disk      : ${TARGET_DISK}"
  [[ -n "${TARGET_DISK_SERIAL}" ]] && \
    echo "  Disk serial  : ${TARGET_DISK_SERIAL}"
  echo "  DATA disk    : ${DATA_DISK}"
  echo "  OS artifact  : ${OS_ARTIFACT_REF}"
  echo "  OS SHA256    : ${OS_IMAGE_SHA256}"
  echo "  Hostname     : ${OURBOX_HOSTNAME}"
  echo "  Username     : ${OURBOX_USERNAME}"
  echo
  echo "  WARNING: ALL DATA ON ${TARGET_DISK} AND ${DATA_DISK} WILL BE PERMANENTLY ERASED."
  echo "  If ${DATA_DISK} contains old LVM, RAID, or encrypted storage,"
  echo "  those structures will be destroyed before Ubuntu installation starts."
  echo
  prompt_confirm_exact "INSTALL" "  Type INSTALL to begin (or Ctrl-C to abort):"

  TARGET_DISK_REAL="$(readlink -f "${TARGET_DISK}")"
  DATA_DISK_REAL="$(readlink -f "${DATA_DISK}")"

  echo
  echo "  Preparing DATA disk now..."
  echo "  This may take a moment if the disk contains old LVM, RAID, or encrypted metadata."
  echo
  /bin/bash /cdrom/ourbox/tools/format-data-disk.sh "${DATA_DISK_REAL}" "${TARGET_DISK_REAL}"
  echo
  echo "  DATA disk prepared successfully."
  echo

  # --- generate autoinstall.yaml ---
  export OURBOX_HOSTNAME OURBOX_USERNAME OURBOX_PASSWORD_HASH

  # Match by device path (for example /dev/nvme0n1 or /dev/sda) rather than serial number.
  # Subiquity's prober reads the serial directly from sysfs, which includes
  # trailing spaces (e.g. "794PCBKPPQKN        ").  lsblk strips those spaces,
  # so a serial-based match always fails.  Path matching is unambiguous and
  # requires no serial normalization.
  OURBOX_STORAGE_MATCH="        path: ${TARGET_DISK_REAL}"
  export OURBOX_STORAGE_MATCH

  [[ -f "${AUTOINSTALL_TPL}" ]] || die "missing runtime template: ${AUTOINSTALL_TPL}"

  # shellcheck disable=SC2016  # single-quoted intentionally — envsubst needs literal $VAR strings
  RUNTIME_VARS='${OURBOX_HOSTNAME} ${OURBOX_USERNAME} ${OURBOX_PASSWORD_HASH} ${OURBOX_STORAGE_MATCH}'
  envsubst "${RUNTIME_VARS}" < "${AUTOINSTALL_TPL}" > "${AUTOINSTALL_OUT}"

  echo
  echo "  =================================================================="
  echo "  Handoff summary"
  echo "  =================================================================="
  echo "  OS disk       : ${TARGET_DISK} (${TARGET_DISK_REAL})"
  echo "  DATA disk     : ${DATA_DISK}"
  echo "  OS artifact   : ${OS_ARTIFACT_REF}"
  echo "  OS SHA256     : ${OS_IMAGE_SHA256}"
  echo "  Hostname      : ${OURBOX_HOSTNAME}"
  echo "  Username      : ${OURBOX_USERNAME}"
  echo "  Autoinstall   : ${AUTOINSTALL_OUT}"
  echo "  =================================================================="
  echo
  echo "  Handing off to Subiquity. Ubuntu base install begins now."
  echo
  echo "  Progress is shown below as Subiquity runs."
  echo "  The machine will POWER OFF when installation is complete."
  echo "  Do NOT remove the USB stick until the machine powers off."
  echo "  When power is off: remove USB, then press power button to boot."
  echo
  echo "  To diagnose issues during this phase (on another TTY):"
  echo "    Alt-F2  : open a shell"
  echo "    cat /run/ourbox-bootcmd.log     (bootcmd drop-in log)"
  echo "    cat ${AUTOINSTALL_OUT}   (config Subiquity is using)"
  echo "    journalctl -fu ourbox-preinstall.service"
  echo "  =================================================================="
  echo
}

main "$@"
