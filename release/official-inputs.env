# Pinned upstream inputs consumed by the official Woodbox OS payload build.
# These MUST be digest-pinned refs (never floating tags) once the amd64 bundles
# are published by sw-ourbox-os.
#
# To resolve current digests:
#   oras resolve ghcr.io/techofourown/sw-ourbox-os/platform-contract:edge
#   oras resolve ghcr.io/techofourown/sw-ourbox-os/airgap-platform:edge-amd64
#
# Update via PR when sw-ourbox-os publishes a new official bundle.

PLATFORM_CONTRACT_REF=ghcr.io/techofourown/sw-ourbox-os/platform-contract@sha256:124f0f2b7f0f9ea70d87ddcc5b98cc07408dd110c42f73e81e331c0e065b5091

# AIRGAP_PLATFORM_REF must be pinned to the amd64 bundle digest once published.
# Until then, the tag form is used as a bootstrap reference.
# Replace with: ghcr.io/techofourown/sw-ourbox-os/airgap-platform@sha256:<amd64-digest>
AIRGAP_PLATFORM_REF=ghcr.io/techofourown/sw-ourbox-os/airgap-platform:edge-amd64

# UBUNTU_ISO_URL and UBUNTU_ISO_SHA256 pin the base installer ISO.
# Verify SHA256 from: https://releases.ubuntu.com/24.04.3/SHA256SUMS
UBUNTU_ISO_URL=https://releases.ubuntu.com/24.04.3/ubuntu-24.04.3-live-server-amd64.iso
UBUNTU_ISO_SHA256=c3514bf0056180d09376462a7a1b4f213c1d6e8ea67fae5c25099c6fd3d8274b

# INSTALL_DEFAULTS_REF is the OCI ref for the remote install-defaults bundle.
# When set, build-installer-iso.sh bakes it into defaults.env so the installer
# can pull a refreshed copy at install time (with the baked value as fallback ref).
# Set to empty until sw-ourbox-os publishes install-defaults artifacts for x86.
INSTALL_DEFAULTS_REF=
