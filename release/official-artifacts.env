# Official publication targets for OurBox Woodbox.
# These values are repo-defined and must never be accepted from workflow inputs
# in the official publication lane.

OURBOX_TARGET=x86
OURBOX_MODEL_ID=TOO-OBX-WBX-01
OURBOX_SKU=TOO-OBX-WBX-BASE-JU3XK8
OURBOX_VARIANT=prod

OFFICIAL_OS_REPO=ghcr.io/techofourown/ourbox-woodbox-os
OFFICIAL_OS_CATALOG_TAG=x86-catalog
OFFICIAL_OS_NIGHTLY_CHANNELS="x86-nightly"
OFFICIAL_OS_RELEASE_CHANNELS="x86-stable"

OFFICIAL_INSTALLER_REPO=ghcr.io/techofourown/ourbox-woodbox-installer
OFFICIAL_INSTALLER_NIGHTLY_CHANNELS="x86-installer-nightly"
OFFICIAL_INSTALLER_RELEASE_CHANNELS="x86-installer-stable"
