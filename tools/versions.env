# tools/versions.env
# Host tooling pins for OurBox Woodbox builds.
# Platform software versions (k3s, app images) are now consumed from sw-ourbox-os
# via the airgap-platform OCI artifact — they are NOT pinned here.

# Ubuntu Server LTS ISO to base the installer on.
# NOTE: If you change this, re-test end-to-end. Update UBUNTU_ISO_SHA256 to match.
UBUNTU_ISO_URL="https://releases.ubuntu.com/24.04.3/ubuntu-24.04.3-live-server-amd64.iso"
# SHA-256 of the base Ubuntu ISO. Verify from:
#   https://releases.ubuntu.com/24.04.3/SHA256SUMS
# and match the line for ubuntu-24.04.3-live-server-amd64.iso
UBUNTU_ISO_SHA256="c3514bf0056180d09376462a7a1b4f213c1d6e8ea67fae5c25099c6fd3d8274b"

# ORAS version installed by tools/bootstrap-host.sh (host-side)
ORAS_VERSION=1.3.0
