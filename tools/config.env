# tools/config.env
# Default identity inputs for this repo.
# Uses conditional assignment (:=) so that environment variables set by CI
# workflows (e.g. OURBOX_VERSION from official-nightly.yml) are not clobbered.

: "${OURBOX_PRODUCT:=ourbox}"
: "${OURBOX_DEVICE:=woodbox}"
: "${OURBOX_TARGET:=x86}"
: "${OURBOX_SKU:=TOO-OBX-WBX-BASE-JU3XK8}"
: "${OURBOX_VARIANT:=prod}"   # prod | dev | exp-foo
: "${OURBOX_VERSION:=dev}"    # v0.1.0 in releases; dev/ci locally

# Hostname that will be configured on the installed OS.
# IMPORTANT: Must match the Ingress hosts baked into manifests.
: "${OURBOX_HOSTNAME:=ourbox-woodbox}"
